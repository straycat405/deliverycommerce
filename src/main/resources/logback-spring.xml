<?xml version="1.0" encoding="UTF-8"?>
<configuration>

    <!-- 콘솔 출력 패턴 정의 -->
    <property name="CONSOLE_PATTERN"
              value="%d{HH:mm:ss.SSS} [%thread] %highlight(%-5level) %cyan(%logger{36}) - %msg%n"/>

    <!-- 파일 출력 패턴 (색상 코드 제거) -->
    <property name="FILE_PATTERN"
              value="%d{yyyy-MM-dd HH:mm:ss.SSS} [%thread] %-5level %logger{36} - %msg%n"/>

    <!-- ① 콘솔 Appender -->
    <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>${CONSOLE_PATTERN}</pattern>
            <charset>UTF-8</charset>
        </encoder>
    </appender>

    <!-- ② 파일 Appender (날짜별 롤링) -->
    <appender name="FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <file>logs/app.log</file>
        <rollingPolicy class="ch.qos.logback.core.rolling.TimeBasedRollingPolicy">
            <!-- 날짜별로 파일 분리: app.2026-02-27.log -->
            <fileNamePattern>logs/app.%d{yyyy-MM-dd}.log</fileNamePattern>
            <!-- 30일치만 보관 -->
            <maxHistory>30</maxHistory>
        </rollingPolicy>
        <encoder>
            <pattern>${FILE_PATTERN}</pattern>
            <charset>UTF-8</charset>
        </encoder>
    </appender>

    <!-- 개발 프로파일일 때만 적용 -->
    <springProfile name="dev, default">
        <root level="INFO">
            <appender-ref ref="CONSOLE"/>
            <appender-ref ref="FILE"/>
        </root>

        <!-- 프로젝트 패키지 → DEBUG -->
        <logger name="com.babjo.deliverycommerce" level="DEBUG" additivity="false">
            <appender-ref ref="CONSOLE"/>
            <appender-ref ref="FILE"/>
        </logger>

        <!-- p6spy로 대체 -->
<!--        &lt;!&ndash; Hibernate SQL &ndash;&gt;-->
<!--        <logger name="org.hibernate.sql" level="DEBUG" additivity="false">-->
<!--            <appender-ref ref="CONSOLE"/>-->
<!--            <appender-ref ref="FILE"/>-->
<!--        </logger>-->

<!--        &lt;!&ndash; Hibernate 바인딩 파라미터 &ndash;&gt;-->
<!--        <logger name="org.hibernate.orm.jdbc.bind" level="TRACE" additivity="false">-->
<!--            <appender-ref ref="CONSOLE"/>-->
<!--            <appender-ref ref="FILE"/>-->
<!--        </logger>-->

    </springProfile>

    <!-- 운영 프로파일 -->
    <springProfile name="prod">
        <root level="WARN">
            <appender-ref ref="FILE"/>
        </root>
    </springProfile>

</configuration>